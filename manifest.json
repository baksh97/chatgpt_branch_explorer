{
  "manifest_version": 3,
  "name": "ChatGPT Branch Explorer",
  "version": "1.0.0",
  "description": "Visualise and navigate ChatGPT's built-in conversation branches in a clear sidebar tree.",

  "permissions": ["storage", "activeTab"],

  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "Toggle Branch Explorer",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["graph.js", "content.js"],
      "css": ["sidebar.css", "graph.css"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
